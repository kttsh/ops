{
	"name": "ops",
	"private": true,
	"packageManager": "pnpm@10.28.2",
	"scripts": {
		"build": "turbo run build",
		"dev": "turbo run dev",
		"lint": "biome check .",
		"lint:fix": "biome check . --write",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"test": "turbo run test",
		"clean": "turbo run clean && rm -rf node_modules"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.13",
		"turbo": "^2.8.0"
	},
	"engines": {
		"node": ">=20"
	}
}
